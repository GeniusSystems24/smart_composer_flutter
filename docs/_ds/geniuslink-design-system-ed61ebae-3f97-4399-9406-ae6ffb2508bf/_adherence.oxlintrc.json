{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "NavigationSidebar.app.jsx",
              "Settings.app.jsx",
              "app.jsx",
              "design_system/**",
              "geniuslink_design_system_flutter/docs/**",
              "ios-frame.jsx",
              "mobile-dashboard/**",
              "tweaks-panel.jsx",
              "ui_kits/genius_link_desktop/**",
              "ui_kits/genius_link_mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Inter|Noto Naskh Arabic|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Inter, Noto Naskh Arabic, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
